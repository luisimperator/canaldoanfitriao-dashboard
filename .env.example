# Modelo de variáveis de ambiente do dashboard.
# Copie para .env.local e preencha. Em produção (ex.: Vercel), cadastre as
# mesmas variáveis nas configurações do projeto.

# ── Supabase (banco de dados) ──────────────────────────────────────────────
# Sem isto o dashboard roda em modo demonstração (dados fictícios).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Eduzz (vendas) ─────────────────────────────────────────────────────────
# Chave validada no webhook /api/webhooks/eduzz
EDUZZ_WEBHOOK_KEY=

# ── TMB (pagamentos pix / boleto) ──────────────────────────────────────────
TMB_WEBHOOK_KEY=

# ── Unnichat (CRM / atendimento) ───────────────────────────────────────────
UNNICHAT_WEBHOOK_KEY=

# ── Meta Ads (tráfego) ─────────────────────────────────────────────────────
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=          # formato act_1234567890

# ── Mailchimp (captação) ───────────────────────────────────────────────────
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=

# ── Banco Inter (financeiro / extrato via API) ─────────────────────────────
# Crie uma aplicação no Internet Banking PJ (menu Aplicações) com o escopo
# "extrato.read" e baixe o certificado mTLS (.crt + .key).
INTER_CLIENT_ID=
INTER_CLIENT_SECRET=
# Cole o CONTEÚDO dos arquivos PEM (não o caminho). Pode usar aspas e \n para
# representar as quebras de linha, ou colar o texto em múltiplas linhas.
INTER_CERT_PEM=
INTER_KEY_PEM=
# Opcional: número da conta-corrente, quando a aplicação acessa mais de uma.
INTER_CONTA_CORRENTE=
